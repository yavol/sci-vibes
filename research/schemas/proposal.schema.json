{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sci-vibes.local/schemas/proposal.schema.json",
  "title": "Sci Vibes branch proposal",
  "description": "A human-comparable, pre-implementation architecture proposal.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "branchId",
    "title",
    "shortName",
    "thesis",
    "summary",
    "architecture",
    "trainingPlan",
    "inductiveBiases",
    "visibleMetrics",
    "strengths",
    "risks",
    "falsificationTests",
    "expectedComplexity",
    "expectedRuntime",
    "humanQuestions",
    "comparisonHook"
  ],
  "properties": {
    "branchId": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,63}$" },
    "title": { "type": "string", "minLength": 6, "maxLength": 140 },
    "shortName": { "type": "string", "minLength": 2, "maxLength": 40 },
    "thesis": { "type": "string", "minLength": 20, "maxLength": 520 },
    "summary": { "type": "string", "minLength": 80, "maxLength": 1400 },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nodes", "edges"],
      "properties": {
        "nodes": {
          "type": "array",
          "minItems": 2,
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "label", "detail"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,31}$" },
              "label": { "type": "string", "minLength": 2, "maxLength": 48 },
              "detail": { "type": "string", "minLength": 8, "maxLength": 420 }
            }
          }
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["from", "to", "label"],
            "properties": {
              "from": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,31}$" },
              "to": { "type": "string", "pattern": "^[a-z][a-z0-9_-]{0,31}$" },
              "label": { "type": "string", "minLength": 1, "maxLength": 80 }
            }
          }
        }
      }
    },
    "trainingPlan": { "$ref": "#/$defs/shortList" },
    "inductiveBiases": { "$ref": "#/$defs/shortList" },
    "visibleMetrics": { "$ref": "#/$defs/shortList" },
    "strengths": { "$ref": "#/$defs/shortList" },
    "risks": { "$ref": "#/$defs/shortList" },
    "falsificationTests": { "$ref": "#/$defs/shortList" },
    "expectedComplexity": { "type": "string", "minLength": 12, "maxLength": 520 },
    "expectedRuntime": { "type": "string", "minLength": 8, "maxLength": 420 },
    "humanQuestions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": { "type": "string", "minLength": 12, "maxLength": 220 }
    },
    "comparisonHook": { "type": "string", "minLength": 20, "maxLength": 520 }
  },
  "$defs": {
    "shortList": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": { "type": "string", "minLength": 8, "maxLength": 520 }
    }
  }
}
