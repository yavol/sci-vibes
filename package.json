{
	"name": "sci-vibes",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "node scripts/run-dev.mjs",
		"dev:vite": "vite dev",
		"dev:server": "scripts/dev-server.sh start",
		"research:manager": "node scripts/research-manager.mjs daemon",
		"research:start": "node scripts/research-manager.mjs start-demo",
		"research:state": "node scripts/research-manager.mjs state",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@openai/codex-sdk": "^0.144.1"
	}
}
